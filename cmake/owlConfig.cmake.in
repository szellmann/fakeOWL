include("${CMAKE_CURRENT_LIST_DIR}/owl_Exports.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/configure_fake_owl.cmake")

check_required_components("owl")

set(CMAKE_MODULE_PATH ${CMAKE_MODULE_PATH_TMP})
